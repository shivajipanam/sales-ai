# Optional: Get free key at https://console.groq.com/keys
# Without this, search works but AI summaries are basic text
GROQ_API_KEY=your_groq_api_key_here

# Optional: For live Amazon deal refresh (paid)
# Without this, app uses seed data (real deals from Aug 2023)
# Get key at https://rainforestapi.com/
RAINFOREST_API_KEY=your_rainforest_api_key_here

# Optional: Override mock URL for Rainforest (leave blank to use default mock)
# RAINFOREST_BASE_URL=https://api.rainforestapi.com/request
